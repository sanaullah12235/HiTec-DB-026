# ────────────────────────────────────────────────────────────────────
# HiSUP — Environment Variables
# ────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
#   cp .env.example .env
#
# NEVER commit .env to version control. It is in .gitignore.
#
# Key separation principle:
#   NEXT_PUBLIC_* → bundled in browser JS (public anon key)
#   Everything else → server-only (NEVER in client bundle)
# ────────────────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════════
# SECTION 1 — Public (Next.js client-side)
# ════════════════════════════════════════════════════════════════════
# These are safe to expose to the browser. They enable the Supabase
# client library to connect, but the anon key has RLS enforced.
# Get these from: Supabase Dashboard → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ════════════════════════════════════════════════════════════════════
# SECTION 2 — Private Service Keys (server-only)
# ════════════════════════════════════════════════════════════════════
# NEVER expose these to the client. They bypass RLS and have admin
# privileges. Only use in API routes, server actions, or migration
# scripts.

# Service role key — bypasses RLS, full admin access
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct database connection URL (optional — only if you need raw PG)
# SUPABASE_DB_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# ════════════════════════════════════════════════════════════════════
# SECTION 3 — Application Secrets
# ════════════════════════════════════════════════════════════════════

# Passphrase for pgp_sym_encrypt/pgp_sym_decrypt used in the DB.
# Must be at least 16 characters. Set the same value server-side:
#   ALTER DATABASE postgres SET app.encryption_passphrase TO '...';
ENCRYPTION_PASSPHRASE=change-me-to-at-least-16-characters

# ════════════════════════════════════════════════════════════════════
# SECTION 4 — Runtime Configuration
# ════════════════════════════════════════════════════════════════════

NODE_ENV=development

# Optional — log verbosity (debug | info | warn | error)
# LOG_LEVEL=info
