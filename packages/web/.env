# ────────────────────────────────────────────────────────────────────
# HiSUP — Environment Variables
# ────────────────────────────────────────────────────────────────────

# ════════════════════════════════════════════════════════════════════
# SECTION 1 — Public (Next.js client-side)
# ════════════════════════════════════════════════════════════════════

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ════════════════════════════════════════════════════════════════════
# SECTION 2 — Private Service Keys (server-only)
# ════════════════════════════════════════════════════════════════════

SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ════════════════════════════════════════════════════════════════════
# SECTION 3 — Application Secrets
# ════════════════════════════════════════════════════════════════════

ENCRYPTION_PASSPHRASE=change-me-to-at-least-16-characters

# ════════════════════════════════════════════════════════════════════
# SECTION 4 — Runtime Configuration
# ════════════════════════════════════════════════════════════════════

NODE_ENV=development
